{
  "entities": {
    "enquiry": {
      "title": "Enquiry",
      "description": "Student enquiry submitted from the public portal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "country": { "type": "string" },
        "program": { "type": "string" },
        "message": { "type": "string" },
        "source": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["New", "Contacted"] }
      },
      "required": ["name", "phone", "program", "source", "date", "status"]
    },
    "admin_config": {
      "title": "AdminConfig",
      "description": "Secure settings and password for the admin dashboard",
      "type": "object",
      "properties": {
        "passwordHash": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["passwordHash"]
    }
  },
  "firestore": {
    "/enquiries/{enquiryId}": {
      "schema": "enquiry",
      "description": "Student enquiry collection"
    },
    "/admin_config/{configId}": {
      "schema": "admin_config",
      "description": "Admin configuration and secure login credentials"
    }
  }
}
